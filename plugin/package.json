{
  "name": "obsidian-code-runner-plugin",
  "version": "0.0.1",
  "description": "Code runner plugin for Obsidian (https://obsidian.md)",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint ."
  },
  "keywords": [],
  "devDependencies": {
    "esbuild": "0.27.3"
  },
  "dependencies": {
    "obsidian": "1.12.2"
  }
}
